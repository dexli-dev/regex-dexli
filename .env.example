# regex · dexli.dev — runtime configuration
#
# Copy this file to `.env` and edit, or set these variables directly in your
# runtime (Docker `-e VAR=value`, Dokploy env panel, systemd EnvironmentFile,
# etc.). Anything left unset uses the default shown after `=`.
#
# Misconfiguration is loud: an unparseable or out-of-bounds value throws at
# startup so a typo fails fast instead of running with the wrong setting.

# ── Network ─────────────────────────────────────────────────────────────────

# Bind port for the Node server (read by SvelteKit's adapter-node).
PORT=3000

# Bind interface. 0.0.0.0 listens on all interfaces; use 127.0.0.1 for
# loopback-only behind a reverse proxy on the same host.
HOST=0.0.0.0

# Public origin used server-side when generating absolute share URLs (e.g. a
# permalink encoding a regex pattern + test text in the query). When unset,
# the server derives the origin from the incoming request (works fine behind
# a reverse proxy that forwards Host correctly). When set, this overrides —
# operator's word is final. Must be an origin only (scheme + host + optional
# port), no path.
#
# PROD: PUBLIC_BASE_URL=https://regex.dexli.dev
PUBLIC_BASE_URL=
